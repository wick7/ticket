# Secret used to sign login sessions — make this long and random
JWT_SECRET=replace-with-a-long-random-string

# AES-256-GCM key for encrypting OAuth tokens — 32 random bytes in hex
ENCRYPTION_KEY=replace-with-32-random-bytes-hex

# Database password — used internally, never exposed to the browser
DB_PASSWORD=replace-with-a-strong-password

# Groq API key for AI ticket classification
GROQ_API_KEY=your_groq_api_key_here

# Slack OAuth credentials
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REDIRECT_URI=http://localhost:3000/api/sources/slack/callback

# Microsoft OAuth credentials (Outlook + Teams)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost:3000/api/sources/microsoft/callback

# Google OAuth credentials (Gmail)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/sources/gmail/callback
