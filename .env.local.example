# Copy this to .env.local and fill in your values

# Database (Docker PostgreSQL)
DATABASE_URL="postgresql://ticketflow:ticketflow@localhost:5432/ticketflow"

# App auth — pick any password you want
LOCAL_PASSWORD="changeme"

# JWT secret — generate with: openssl rand -base64 32
JWT_SECRET="your-secret-here"

# Encryption key for OAuth tokens — generate with: openssl rand -hex 32
ENCRYPTION_KEY="your-32-byte-hex-key-here"

# Claude API key — get from https://console.anthropic.com
ANTHROPIC_API_KEY="sk-ant-..."

# Slack app credentials (set up at https://api.slack.com/apps)
SLACK_CLIENT_ID=""
SLACK_CLIENT_SECRET=""
SLACK_REDIRECT_URI="http://localhost:3000/api/sources/slack/callback"

# Microsoft app credentials (set up at https://portal.azure.com)
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""
MICROSOFT_REDIRECT_URI="http://localhost:3000/api/sources/microsoft/callback"

# How often to auto-sync in the background (minutes, default: 15)
POLL_INTERVAL_MINUTES=15
